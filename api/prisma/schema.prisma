// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}


datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}


model Enrollment {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  cpf       String   @unique
  phone     String
  birthDate DateTime?
  
  modality String
  amount Float
  classDay String? // Dia da semana (Segunda, Terça, etc)

  status String @default("PENDING")
  paymentId String?
  passwordHash String?
  lastAccess DateTime?

  createdAt DateTime @default(now())

  lessonProgress LessonProgress[] // Histórico de aulas assistidas
  examAttempts   ExamAttempt[]
  moduleProgress ModuleProgress[]
  refreshTokens RefreshToken[]
  notices Notice[]
  comments LessonComment[]
}

model LessonComment {
  id        String   @id @default(uuid())
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  enrollmentId String
  lessonId String
  content String @db.Text
  createdAt DateTime @default(now())

  @@index([enrollmentId])
  @@index([lessonId])
}

enum LessonStatus {
  IN_PROGRESS
  COMPLETED
}

model LessonProgress {
  id String @id @default(uuid())
  studentName String?
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  enrollmentId String
  lessonId String
  watchedSeconds Int @default(0)
  status LessonStatus @default(IN_PROGRESS)
  watchedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enrollmentId])
  @@index([lessonId])
}

model ExamAttempt {
  id String @id @default(uuid())
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  enrollmentId String
  examId String
  moduleId String?
  score Float
  maxScore Float
  takenAt DateTime @default(now())

  @@index([enrollmentId])
  @@index([examId])
  @@index([moduleId])
}

model ModuleProgress {
  id String @id @default(uuid())
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  enrollmentId String
  moduleId String
  averageScore Float @default(0)
  examsTakenCount Int @default(0)
  lastUpdated DateTime @updatedAt

  @@unique([enrollmentId, moduleId])
  @@index([enrollmentId])
}

model RefreshToken {
  id String @id @default(uuid())
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  enrollmentId String
  tokenHash String
  createdAt DateTime @default(now())
  expiresAt DateTime
  revoked Boolean @default(false)
  replacedById String?
  replacedBy RefreshToken? @relation("RefreshTokenReplacement", fields: [replacedById], references: [id])
  replaced RefreshToken[] @relation("RefreshTokenReplacement")

  @@index([enrollmentId])
  @@index([tokenHash])
}




model Notice {
  id String @id @default(uuid())
  title String
  content String @db.LongText
  category String?
  date DateTime @default(now())
  createdBy Enrollment? @relation(fields: [createdById], references: [id])
  createdById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}




model VideoLesson {
  id               String   @id @default(uuid())
  module           Int
  subjectOrder     Int
  subjectName      String
  lessonOrder      Int
  title            String
  vimeoId          String?
  duration         Int?
  requiredModality String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([module, subjectOrder])
}

model PdfMaterial {
  id           String   @id @default(uuid())
  module       Int
  subjectOrder Int
  subjectName  String
  category     String
  modality     String?
  filename     String
  title        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([module, subjectOrder])
}

model Coupon {
  id        String   @id @default(uuid())
  code      String   @unique
  discount  Float
  type      String   @default("PERCENTAGE") // "PERCENTAGE" ou "FIXED_PRICE"
  createdAt DateTime @default(now())
}

model SimuladoSubmission {
  id           String   @id @default(uuid())
  studentName  String
  simuladoId   String   // Ex.: "simulado1"
  startedAt    DateTime @default(now())
  submittedAt  DateTime?
  timeLimit    Int      // Em minutos, ex.: 60
  timeSpent    Int?     // Em segundos, tempo real usado
  totalScore   Float?   // Ex.: 15.0
  percentage   Float?   // Calculado automaticamente

  responses    SimuladoResponse[]

  @@unique([studentName, simuladoId]) // Uma submissão por aluno/simulado
  @@index([studentName])
  @@index([simuladoId])
}

model SimuladoResponse {
  id           String   @id @default(uuid())
  submission   SimuladoSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId String
  studentName  String?
  questionIndex Int    // 0-based
  selectedOption String? // "A", "B", etc.
  flagged      Boolean @default(false)
  isCorrect    Boolean? // true/false baseado na resposta correta

  @@unique([submissionId, questionIndex]) // Uma resposta por questão por submissão
  @@index([submissionId])
}
